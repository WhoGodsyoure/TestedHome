local AzureUI = {}

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function AddStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Color3.fromRGB(115, 90, 40)
    stroke.Thickness = thickness or 1.4
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = parent
    return stroke
end

local Accent = Color3.fromRGB(255, 215, 0)
local MainBg     = Color3.fromRGB(20, 18, 16)
local SidebarBg  = Color3.fromRGB(30, 26, 22)
local ContentBg  = Color3.fromRGB(36, 32, 26)
local TextPrimary   = Color3.fromRGB(245, 245, 220)
local TextSecondary = Color3.fromRGB(200, 180, 60)
local Hover      = Color3.fromRGB(60, 50, 30)

local ColorPresets = {
    Red     = Color3.fromRGB(255, 0, 0),
    Orange  = Color3.fromRGB(255, 165, 0),
    Yellow  = Color3.fromRGB(255, 215, 0),
    Green   = Color3.fromRGB(0, 200, 0),
    Blue    = Color3.fromRGB(0, 120, 255),
    Indigo  = Color3.fromRGB(75, 0, 130),
    Violet  = Color3.fromRGB(148, 0, 211),
    White   = Color3.fromRGB(255, 255, 255),
    Black   = Color3.fromRGB(0, 0, 0),
}

local elementOrder = 0

-- ==================== CREATE BUTTON ====================
function AzureUI:CreateButton(parent, title, desc, callback)
    elementOrder = elementOrder - 1
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 50)
    btn.BackgroundColor3 = ContentBg
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.LayoutOrder = elementOrder
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    AddStroke(btn, Accent, 1.2)

    local titleLbl = Instance.new("TextLabel", btn)
    titleLbl.Size = UDim2.new(1, -24, 0, 26)
    titleLbl.Position = UDim2.new(0, 12, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = TextPrimary
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 16
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local descLbl = Instance.new("TextLabel", btn)
    descLbl.Size = UDim2.new(1, -24, 0, 18)
    descLbl.Position = UDim2.new(0, 12, 0, 30)
    descLbl.BackgroundTransparency = 1
    descLbl.Text = desc or ""
    descLbl.TextColor3 = TextSecondary
    descLbl.Font = Enum.Font.Gotham
    descLbl.TextSize = 13
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.TextWrapped = true

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = Hover}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = ContentBg}):Play()
    end)

    btn.MouseButton1Click:Connect(callback or function() end)
    return btn
end

-- ==================== CREATE TOGGLE ====================
function AzureUI:CreateToggle(parent, title, desc, callback)
    elementOrder = elementOrder - 1
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 54)
    frame.BackgroundColor3 = ContentBg
    frame.LayoutOrder = elementOrder
    frame.Parent = parent
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    AddStroke(frame, Accent, 1.2)

    local titleLbl = Instance.new("TextLabel", frame)
    titleLbl.Size = UDim2.new(0.62, 0, 0, 26)
    titleLbl.Position = UDim2.new(0, 12, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = TextPrimary
    titleLbl.Font = Enum.Font.GothamSemibold
    titleLbl.TextSize = 15
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local descLbl = Instance.new("TextLabel", frame)
    descLbl.Size = UDim2.new(0.62, 0, 0, 18)
    descLbl.Position = UDim2.new(0, 12, 0, 32)
    descLbl.BackgroundTransparency = 1
    descLbl.Text = desc or ""
    descLbl.TextColor3 = TextSecondary
    descLbl.Font = Enum.Font.Gotham
    descLbl.TextSize = 12
    descLbl.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", frame)
    track.Name = "Track"
    track.Size = UDim2.new(0, 48, 0, 24)
    track.Position = UDim2.new(1, -60, 0.5, -12)
    track.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", track)
    circle.Name = "Circle"
    circle.Size = UDim2.new(0, 20, 0, 20)
    circle.Position = UDim2.new(0, 2, 0.5, -10)
    circle.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local enabled = false

    local function updateVisual()
        if enabled then
            TweenService:Create(track, TweenInfo.new(0.22), {BackgroundColor3 = Accent}):Play()
            TweenService:Create(circle, TweenInfo.new(0.22), {Position = UDim2.new(1, -22, 0.5, -10)}):Play()
        else
            TweenService:Create(track, TweenInfo.new(0.22), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}):Play()
            TweenService:Create(circle, TweenInfo.new(0.22), {Position = UDim2.new(0, 2, 0.5, -10)}):Play()
        end
    end

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            enabled = not enabled
            updateVisual()
            task.spawn(function() callback(enabled) end)
        end
    end)

    return {
        Toggle = function(state)
            enabled = state
            updateVisual()
        end,
        IsEnabled = function() return enabled end
    }
end

-- ==================== CREATE DROPDOWN ====================
function AzureUI:CreateDropdown(parent, title, options, default, callback)
    elementOrder = elementOrder - 1
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundColor3 = ContentBg
    frame.LayoutOrder = elementOrder
    frame.Parent = parent
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    AddStroke(frame, Accent, 1.2)

    local titleLbl = Instance.new("TextLabel", frame)
    titleLbl.Size = UDim2.new(1, -50, 1, 0)
    titleLbl.Position = UDim2.new(0, 12, 0, 0)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = TextPrimary
    titleLbl.Font = Enum.Font.GothamSemibold
    titleLbl.TextSize = 16
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local selectedLbl = Instance.new("TextLabel", frame)
    selectedLbl.Size = UDim2.new(0, 120, 1, 0)
    selectedLbl.Position = UDim2.new(1, -140, 0, 0)
    selectedLbl.BackgroundTransparency = 1
    selectedLbl.Text = default or options[1] or "None"
    selectedLbl.TextColor3 = TextSecondary
    selectedLbl.Font = Enum.Font.Gotham
    selectedLbl.TextSize = 15
    selectedLbl.TextXAlignment = Enum.TextXAlignment.Right

    local arrow = Instance.new("TextLabel", frame)
    arrow.Size = UDim2.new(0, 30, 1, 0)
    arrow.Position = UDim2.new(1, -35, 0, 0)
    arrow.BackgroundTransparency = 1
    arrow.Text = "▼"
    arrow.TextColor3 = Accent
    arrow.Font = Enum.Font.GothamBold
    arrow.TextSize = 18

    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.Size = UDim2.new(1, 0, 0, 0)
    dropdownFrame.Position = UDim2.new(0, 0, 1, 5)
    dropdownFrame.BackgroundColor3 = ContentBg
    dropdownFrame.ClipsDescendants = true
    dropdownFrame.Visible = false
    dropdownFrame.Parent = frame
    Instance.new("UICorner", dropdownFrame).CornerRadius = UDim.new(0, 8)
    AddStroke(dropdownFrame, Accent, 1.2)

    local listLayout = Instance.new("UIListLayout", dropdownFrame)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 4)

    local isOpen = false
    local currentValue = default or options[1] or ""

    local function toggleDropdown()
        isOpen = not isOpen
        if isOpen then
            dropdownFrame.Visible = true
            TweenService:Create(dropdownFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, #options * 35 + 10)}):Play()
            arrow.Text = "▲"
        else
            TweenService:Create(dropdownFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 0)}):Play()
            task.delay(0.25, function()
                if not isOpen then dropdownFrame.Visible = false end
            end)
            arrow.Text = "▼"
        end
    end

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            toggleDropdown()
        end
    end)

    for _, opt in ipairs(options) do
        local optionBtn = Instance.new("TextButton")
        optionBtn.Size = UDim2.new(1, -10, 0, 35)
        optionBtn.Position = UDim2.new(0, 5, 0, 0)
        optionBtn.BackgroundColor3 = ContentBg
        optionBtn.Text = opt
        optionBtn.TextColor3 = TextSecondary
        optionBtn.Font = Enum.Font.Gotham
        optionBtn.TextSize = 15
        optionBtn.Parent = dropdownFrame
        Instance.new("UICorner", optionBtn).CornerRadius = UDim.new(0, 6)

        optionBtn.MouseButton1Click:Connect(function()
            currentValue = opt
            selectedLbl.Text = opt
            toggleDropdown()
            if callback then callback(opt) end
        end)

        optionBtn.MouseEnter:Connect(function()
            TweenService:Create(optionBtn, TweenInfo.new(0.15), {BackgroundColor3 = Hover}):Play()
        end)
        optionBtn.MouseLeave:Connect(function()
            TweenService:Create(optionBtn, TweenInfo.new(0.15), {BackgroundColor3 = ContentBg}):Play()
        end)
    end

    return {
        GetValue = function() return currentValue end,
        SetValue = function(val)
            if table.find(options, val) then
                currentValue = val
                selectedLbl.Text = val
            end
        end
    }
end

-- ==================== CREATE GUI ====================
function AzureUI:Create(title)
    if PlayerGui:FindFirstChild("AzureGUIMain") then
        PlayerGui.AzureGUIMain:Destroy()
    end

    elementOrder = 0

    local sg = Instance.new("ScreenGui")
    sg.Name = "AzureGUIMain"
    sg.ResetOnSpawn = false
    sg.IgnoreGuiInset = true
    sg.Parent = PlayerGui

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 58, 0, 58)
    toggleBtn.Position = UDim2.new(0.015, 0, 0.42, 0)
    toggleBtn.BackgroundColor3 = SidebarBg
    toggleBtn.Text = "A"
    toggleBtn.TextColor3 = Accent
    toggleBtn.Font = Enum.Font.GothamBlack
    toggleBtn.TextSize = 42
    toggleBtn.Draggable = true
    toggleBtn.Parent = sg
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
    AddStroke(toggleBtn, Accent, 2.8)

    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, 540, 0, 400)
    main.Position = UDim2.new(0.5, -270, 0.5, -200)
    main.BackgroundColor3 = MainBg
    main.Visible = false
    main.ClipsDescendants = true
    main.Parent = sg
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)
    AddStroke(main, Accent, 1.8)

    local sidebar = Instance.new("Frame")
    sidebar.Size = UDim2.new(0.26, 0, 1, 0)
    sidebar.BackgroundColor3 = SidebarBg
    sidebar.Parent = main
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(0, 12)

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, 0, 0, 54)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Accent
    titleLbl.Font = Enum.Font.GothamBlack
    titleLbl.TextSize = 28
    titleLbl.TextXAlignment = Enum.TextXAlignment.Center
    titleLbl.Parent = sidebar

    local creditFrame = Instance.new("Frame")
    creditFrame.Size = UDim2.new(1, -20, 0, 36)
    creditFrame.Position = UDim2.new(0, 10, 1, -46)
    creditFrame.BackgroundTransparency = 1
    creditFrame.Parent = sidebar

    local creditLbl = Instance.new("TextLabel", creditFrame)
    creditLbl.Size = UDim2.new(1, 0, 1, 0)
    creditLbl.BackgroundTransparency = 1
    creditLbl.Text = "Credit: ArchiveXNova"
    creditLbl.TextColor3 = TextSecondary
    creditLbl.Font = Enum.Font.Gotham
    creditLbl.TextSize = 14
    creditLbl.TextXAlignment = Enum.TextXAlignment.Left

    local tabList = Instance.new("ScrollingFrame")
    tabList.Size = UDim2.new(1, -20, 1, -110)
    tabList.Position = UDim2.new(0, 10, 0, 64)
    tabList.BackgroundTransparency = 1
    tabList.ScrollBarThickness = 2
    tabList.ScrollBarImageColor3 = Accent
    tabList.ScrollingDirection = Enum.ScrollingDirection.Y
    tabList.CanvasSize = UDim2.new(0,0,0,0)
    tabList.Parent = sidebar

    local tabLayout = Instance.new("UIListLayout", tabList)
    tabLayout.Padding = UDim.new(0, 8)
    tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder

    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabList.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 16)
    end)

    local content = Instance.new("ScrollingFrame")
    content.Name = "ContentScroll"
    content.Size = UDim2.new(0.74, 0, 1, 0)
    content.Position = UDim2.new(0.26, 0, 0, 0)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 4
    content.ScrollBarImageColor3 = Color3.fromRGB(90, 80, 60)
    content.ScrollingDirection = Enum.ScrollingDirection.Y
    content.CanvasSize = UDim2.new(0,0,0,0)
    content.Parent = main

    local contentLayout = Instance.new("UIListLayout", content)
    contentLayout.Padding = UDim.new(0, 14)
    contentLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    contentLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.FillDirection = Enum.FillDirection.Vertical

    local contentPad = Instance.new("UIPadding", content)
    contentPad.PaddingTop = UDim.new(0, 20)
    contentPad.PaddingLeft = UDim.new(0, 16)
    contentPad.PaddingRight = UDim.new(0, 16)
    contentPad.PaddingBottom = UDim.new(0, 24)

    contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        content.CanvasSize = UDim2.new(0, 0, 0, contentLayout.AbsoluteContentSize.Y + 60)
    end)

    local function updateAccent(newColor)
        Accent = newColor
        for _, obj in ipairs(sg:GetDescendants()) do
            if obj:IsA("UIStroke") then
                obj.Color = newColor
            end
            if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and (obj.Parent == sidebar or obj == toggleBtn) then
                obj.TextColor3 = newColor
            end
            if obj:IsA("ScrollingFrame") and obj == tabList then
                obj.ScrollBarImageColor3 = newColor
            end
            if obj.Name == "Track" and obj:IsA("Frame") then
                local circle = obj:FindFirstChild("Circle")
                if circle and circle.Position.X.Offset >= 20 then
                    TweenService:Create(obj, TweenInfo.new(0.25), {BackgroundColor3 = newColor}):Play()
                end
            end
            if obj:IsA("Frame") and obj.Size.X.Offset == 6 and obj.Visible then
                TweenService:Create(obj, TweenInfo.new(0.25), {BackgroundColor3 = newColor}):Play()
            end
        end
    end

    -- Dragging & Toggle
    local dragging, dragInput, dragStart
    sidebar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            dragInput = main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(dragInput.X.Scale, dragInput.X.Offset + delta.X, dragInput.Y.Scale, dragInput.Y.Offset + delta.Y)
        end
    end)

    toggleBtn.MouseButton1Click:Connect(function()
        main.Visible = not main.Visible
    end)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.RightControl or input.KeyCode == Enum.KeyCode.X then
            main.Visible = not main.Visible
        elseif input.KeyCode == Enum.KeyCode.Z then
            sg:Destroy()
        end
    end)

    local lib = {}

    function lib:Tab(name)
        local tabContent = Instance.new("ScrollingFrame")
        tabContent.Name = "Tab_" .. name
        tabContent.Size = UDim2.new(1, 0, 1, 0)
        tabContent.BackgroundTransparency = 1
        tabContent.BorderSizePixel = 0
        tabContent.ScrollBarThickness = 4
        tabContent.ScrollBarImageColor3 = Color3.fromRGB(90, 80, 60)
        tabContent.ScrollingDirection = Enum.ScrollingDirection.Y
        tabContent.CanvasSize = UDim2.new(0,0,0,0)
        tabContent.Visible = false
        tabContent.Parent = content

        local tabLayout = Instance.new("UIListLayout", tabContent)
        tabLayout.Padding = UDim.new(0, 12)
        tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
        tabLayout.FillDirection = Enum.FillDirection.Vertical

        local tabPad = Instance.new("UIPadding", tabContent)
        tabPad.PaddingTop = UDim.new(0, 4)
        tabPad.PaddingBottom = UDim.new(0, 12)
        tabPad.PaddingLeft = UDim.new(0, 4)
        tabPad.PaddingRight = UDim.new(0, 4)

        tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabContent.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 30)
        end)

        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(1, 0, 0, 44)
        tabBtn.BackgroundColor3 = SidebarBg
        tabBtn.Text = name
        tabBtn.TextColor3 = TextSecondary
        tabBtn.Font = Enum.Font.GothamSemibold
        tabBtn.TextSize = 16
        tabBtn.AutoButtonColor = false
        tabBtn.Parent = tabList
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)

        local indicator = Instance.new("Frame", tabBtn)
        indicator.Size = UDim2.new(0, 6, 0.6, 0)
        indicator.Position = UDim2.new(0, 6, 0.2, 0)
        indicator.BackgroundColor3 = Accent
        indicator.BorderSizePixel = 0
        indicator.Visible = false

        local function activate()
            for _, child in content:GetChildren() do
                if child:IsA("ScrollingFrame") then child.Visible = false end
            end
            tabContent.Visible = true

            for _, b in tabList:GetChildren() do
                if b:IsA("TextButton") then
                    TweenService:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = SidebarBg, TextColor3 = TextSecondary}):Play()
                    b:FindFirstChild("Frame").Visible = false
                end
            end

            TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3 = ContentBg, TextColor3 = TextPrimary}):Play()
            indicator.Visible = true
            indicator.BackgroundColor3 = Accent
        end

        tabBtn.MouseButton1Click:Connect(activate)
        tabBtn.MouseEnter:Connect(function()
            if not indicator.Visible then
                TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3 = Hover}):Play()
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if not indicator.Visible then
                TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3 = SidebarBg}):Play()
            end
        end)

        if #tabList:GetChildren() == 1 then activate() end

        return tabContent
    end

    -- ==================== CONTOH PENGGUNAAN ====================
    local settingsTab = lib:Tab("Settings")

    -- Contoh lain
    AzureUI:CreateButton(settingsTab, "Change Accent Color", "Choose main theme color", function() end)

    for colorName, colorValue in pairs(ColorPresets) do
        AzureUI:CreateButton(settingsTab, colorName, "Set Accent to " .. colorName, function()
            updateAccent(colorValue)
        end)
    end

    return lib
end

return AzureUI
